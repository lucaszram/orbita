EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_JWT_ISSUER_DOMAIN=
ORBITA_BACKOFFICE_ALLOWED_EMAILS=
# Local/dev escape hatch only. Keep false in shared/prod deployments.
ORBITA_BACKOFFICE_ALLOW_ALL=false
# Public-dev Home Lab. Keep disabled unless intentionally testing /lab.
ORBITA_PUBLIC_LAB_ENABLED=false
ORBITA_PUBLIC_LAB_KEY=

# Server-side only. Set these in Convex env, never in client-exposed EXPO_PUBLIC envs.
ASTROLOGY_API_USER_ID=
ASTROLOGY_API_KEY=
ASTROLOGY_API_BASE_URL=https://json.astrologyapi.com/v1
ASTROLOGY_API_LANGUAGE=en
ASTROLOGY_API_HOUSE_SYSTEM=placidus
# Optional until AstrologyAPI shares the exact Location API endpoint for the account.
ASTROLOGY_API_LOCATION_URL=
# Optional future endpoint for provider-confirmed long windows like "hasta marzo" or "vuelve en 2027".
ASTROLOGY_API_LONG_RANGE_URL=

# Optional LLM layer for /lab. Keep disabled unless testing Gateway spend.
ORBITA_LLM_ENABLED=false
AI_GATEWAY_API_KEY=
# Use Vercel AI Gateway provider/model format, for example anthropic/claude-sonnet-4.6.
ORBITA_LLM_MODEL=
ORBITA_LLM_DAILY_PROMPT_VERSION=orbita-lab-daily-home-llm-v1
ORBITA_LLM_DAILY_CACHE_VERSION=orbita-llm-daily-cache-v1
ORBITA_LLM_NATAL_PROMPT_VERSION=orbita-natal-profile-llm-v1
ORBITA_LLM_NATAL_CACHE_VERSION=orbita-natal-profile-cache-v1

# Legacy until Supabase is fully retired.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
